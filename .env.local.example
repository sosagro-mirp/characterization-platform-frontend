# API Configuration
# Backend API base URL (must include protocol and port)
# Development: http://localhost:3000
# Production (Railway): https://characterization-platform-backend-production.up.railway.app
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Hero video (hosted on Cloudinary)
NEXT_PUBLIC_HERO_VIDEO_URL=https://res.cloudinary.com/ecuot/video/upload/v1779213815/tckqprqgmipwaqo2isqy.mp4

# Maintenance mode — set to "true" to redirect all traffic to /maintenance
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Optional: Sentry error tracking
# NEXT_PUBLIC_SENTRY_DSN=

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=
